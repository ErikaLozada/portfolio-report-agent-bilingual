		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Footer =
			
			VAR _date = TODAY()
			VAR _text = "JLL APAC CAI Team | Data Updated "
			RETURN
			IF(
			    NOT ISBLANK(_date),
			    _text & FORMAT(_date, "dd mmm yy hh:mm AM/PM"),
			    _text & "N/A"
			)
		lineageTag: b560262a-1705-4f32-8d95-7c1593499e9a

	measure 'CF Rent at Risk' = ```
			
			        if(CALCULATE(
			            [Total Annual Rent],
			            DATEDIFF(TODAY(), 'Portfolio'[Lease End Date ], MONTH) <= 36 &&
			            DATEDIFF(TODAY(), 'Portfolio'[Lease End Date ], MONTH) > 0
			        )>0,1,0)
			```
		formatString: 0
		lineageTag: 319a86bf-87f9-4269-a096-94c6368abf4a

	measure 'Upcoming End of Leases Total Area (sqm)' = ```
			
			        CALCULATE(
			            [Total Area (sqm)],
			            DATEDIFF(TODAY(), 'Portfolio'[Lease End Date ], MONTH) <= 36 &&
			            DATEDIFF(TODAY(), 'Portfolio'[Lease End Date ], MONTH) > 0 )
			```
		lineageTag: 5dbf921c-c784-4689-9f4d-8dd75c57ac0b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Owned Area (m2)' = CALCULATE([Total Area (sqm)],  'Portfolio'[Acquisition Type] = "Owned" )
		formatString: #,0
		lineageTag: 291bb8ef-46f0-41a9-ae48-505aca5c9181

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Total Acquisition Cost' = ```
			
			        // Currency selection measure - switches between USD and SAR based on disconnected table
			        VAR _selectedCurr = SELECTEDVALUE('Currency Selection'[CurrencyOrder], 1)
			        RETURN 
			            SWITCH(
			                _selectedCurr, 
			                1, [Total Acquisition Cost (USD)],
			                2,[Total Adquisition Cost (SAR)]
			            )
			```
		formatString: #,0
		lineageTag: 250d2f9e-404e-4b4b-b6cf-9618ca5e6495

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Total Adquisition Cost (SAR)' = ```
			
			        SUMX(
			            'Portfolio',
			            VAR AnnualMultiplier = 
			                SWITCH(
			                    'Portfolio'[Lease Payment Frequency],
			                    "Semi-Annual ", 2,
			                    "Quarterly", 4,
			                    "Annual", 1,
			                    1  // Default to annual if not specified
			                )
			            RETURN
			                'Portfolio'[Acquisition Cost SAR]
			        )
			```
		lineageTag: cd745f14-fd71-437f-882c-e786d8111d17

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Acquisition Cost (USD)' = ```
			
			        // Note: Uses USD/SAR exchange rate from parameter table
			        VAR USDToSARRate = COALESCE(SELECTEDVALUE('USD to AR ExRate'[USD to AR ExRate]), 3.75)
			        RETURN
			            DIVIDE([Total Adquisition Cost (SAR)], USDToSARRate, 0)
			```
		lineageTag: dc280c44-a8b7-4ccb-9af6-36d1fb40bfbc

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Global Median Area' = ```
			
			        CALCULATE(
			            MEDIANX(
			            FILTER(
			                'Portfolio',
			                NOT(ISBLANK('Portfolio'[Total Building Area (m²)])) &&
			                'Portfolio'[Total Building Area (m²)] > 0
			            ),
			            'Portfolio'[Total Building Area (m²)]
			        ), all(Portfolio))
			```
		lineageTag: c161d37f-ddd9-4ce6-90cb-12ef49d9eedf

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Global Median Annual Rent' = ```
			
			       CALCULATE( MEDIANX(
			            FILTER(
			                ADDCOLUMNS(
			                    SUMMARIZE('Portfolio', 'Portfolio'[Site]),
			                    "AnnualRent", [Total Annual Rent with area]
			                ),
			                [AnnualRent] > 0
			            ),
			            [AnnualRent]
			        ), ALL(Portfolio))
			```
		lineageTag: bba6c202-5706-4aea-b631-52634cf4fa81

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Properties with Area above median and Annual Rent above median
	measure 'Quadrant 1 - High Area, High Rent' = ```
			COUNTROWS(
			FILTER(
			        ADDCOLUMNS(
			            SUMMARIZE(
			                FILTER(
			                    'Portfolio',
			                    NOT(ISBLANK('Portfolio'[Total Building Area (m²)])) &&
			                    'Portfolio'[Total Building Area (m²)] > 0
			                ),
			                'Portfolio'[Site]
			            ),
			            "Area", [Total Leased Area (m2)],
			            "AnnualRent", [Total Annual Rent with area],
						"MedianArea"  ,[Global Median Area],
			        	"MedianRent" ,[Global Median Annual Rent] 
			        ),
					        [Area] > [MedianArea] &&
			        [AnnualRent] > [MedianRent] &&
			        NOT(ISBLANK([AnnualRent])) &&
			        [AnnualRent] > 0
			    )
			)
			```
		formatString: #,0
		displayFolder: Quadrant Analysis
		lineageTag: 36d52cde-01e8-4037-897d-4b45eaeb9815

	/// Properties with Area at or below median and Annual Rent above median
	measure 'Quadrant 2 - Low Area, High Rent' = ```
			COUNTROWS(
			FILTER(
			        ADDCOLUMNS(
			            SUMMARIZE(
			                FILTER(
			                    'Portfolio',
			                    NOT(ISBLANK('Portfolio'[Total Building Area (m²)])) &&
			                    'Portfolio'[Total Building Area (m²)] > 0
			                ),
			                'Portfolio'[Site]
			            ),
			            "Area", [Total Leased Area (m2)],
			            "AnnualRent", [Total Annual Rent with area],
						"MedianArea"  ,[Global Median Area],
			        	"MedianRent" ,[Global Median Annual Rent] 
			        ),
					        [Area] <= [MedianArea] &&
			        [AnnualRent] > [MedianRent] &&
			        NOT(ISBLANK([AnnualRent])) &&
			        [AnnualRent] > 0
			    )
			)
			```
		formatString: #,0
		displayFolder: Quadrant Analysis
		lineageTag: 37d7b716-b3f4-42c6-a7f6-aa92030f4a3f

	/// Properties with Area at or below median and Annual Rent at or below median
	measure 'Quadrant 3 - Low Area, Low Rent' = ```
			COUNTROWS(
			FILTER(
			        ADDCOLUMNS(
			            SUMMARIZE(
			                FILTER(
			                    'Portfolio',
			                    NOT(ISBLANK('Portfolio'[Total Building Area (m²)])) &&
			                    'Portfolio'[Total Building Area (m²)] > 0
			                ),
			                'Portfolio'[Site]
			            ),
			            "Area", [Total Leased Area (m2)],
			            "AnnualRent", [Total Annual Rent with area],
						"MedianArea"  ,[Global Median Area],
			        	"MedianRent" ,[Global Median Annual Rent] 
			        ),
					        [Area] <= [MedianArea] &&
			        [AnnualRent] <= [MedianRent] &&
			        NOT(ISBLANK([AnnualRent])) &&
			        [AnnualRent] > 0
			    )
			)
			```
		formatString: #,0
		displayFolder: Quadrant Analysis
		lineageTag: a8b107b7-9325-4214-9276-841e0a037940

	/// Properties with Area above median and Annual Rent at or below median
	measure 'Quadrant 4 - High Area, Low Rent' = ```
			COUNTROWS(
			FILTER(
			        ADDCOLUMNS(
			            SUMMARIZE(
			                FILTER(
			                    'Portfolio',
			                    NOT(ISBLANK('Portfolio'[Total Building Area (m²)])) &&
			                    'Portfolio'[Total Building Area (m²)] > 0
			                ),
			                'Portfolio'[Site]
			            ),
			            "Area", [Total Leased Area (m2)],
			            "AnnualRent", [Total Annual Rent with area],
						"MedianArea"  ,[Global Median Area],
			        	"MedianRent" ,[Global Median Annual Rent] 
			        ),
					        [Area] > [MedianArea] &&
			        [AnnualRent] <= [MedianRent] &&
			        NOT(ISBLANK([AnnualRent])) &&
			        [AnnualRent] > 0
			    )
			)
			```
		formatString: #,0
		displayFolder: Quadrant Analysis
		lineageTag: e542fc7f-33ac-42a6-9378-62932dca39f2

	/// Total count of properties included in quadrant analysis
	measure 'Total Properties in Quadrant Analysis' = [Quadrant 1 - High Area, High Rent] + [Quadrant 2 - Low Area, High Rent] + [Quadrant 3 - Low Area, Low Rent] + [Quadrant 4 - High Area, Low Rent]
		formatString: #,0
		displayFolder: Quadrant Analysis
		lineageTag: b327dbb8-e531-4c8d-9df5-14ac44b3b513

	/// Percentage of properties in Quadrant 1 (High Area, High Rent)
	measure 'Quadrant 1 - % of Total' = DIVIDE([Quadrant 1 - High Area, High Rent], [Total Properties in Quadrant Analysis], 0)
		formatString: 0.0%
		displayFolder: Quadrant Analysis
		lineageTag: 3e07f83f-6ef1-44ce-bc2b-e428c11bd251

	/// Percentage of properties in Quadrant 2 (Low Area, High Rent)
	measure 'Quadrant 2 - % of Total' = DIVIDE([Quadrant 2 - Low Area, High Rent], [Total Properties in Quadrant Analysis], 0)
		formatString: 0.0%
		displayFolder: Quadrant Analysis
		lineageTag: 5d574693-07cc-458a-a3a7-f4e549c95323

	/// Percentage of properties in Quadrant 3 (Low Area, Low Rent)
	measure 'Quadrant 3 - % of Total' = DIVIDE([Quadrant 3 - Low Area, Low Rent], [Total Properties in Quadrant Analysis], 0)
		formatString: 0.0%
		displayFolder: Quadrant Analysis
		lineageTag: f90f3893-7953-4d75-b5cf-0b6fc5e0167a

	/// Percentage of properties in Quadrant 4 (High Area, Low Rent)
	measure 'Quadrant 4 - % of Total' = DIVIDE([Quadrant 4 - High Area, Low Rent], [Total Properties in Quadrant Analysis], 0)
		formatString: 0.0%
		displayFolder: Quadrant Analysis
		lineageTag: 00108700-d69e-472d-81b0-9b3b9f43e4c7

	/// Overall portfolio efficiency combining rent per sqm and utilization
	measure 'Portfolio Efficiency Score' =
			DIVIDE(
			    [Total Annual Rent with area],
			    [Total Area (sqm)],
			    0
			) * [Average Utilization Rate]
		formatString: #,0.00
		displayFolder: Portfolio Analysis
		lineageTag: 6be2cf5d-fb9a-47f7-b49b-aef89d6d0608

	/// Properties with utilization rate below 50%
	measure 'Underutilized Properties Count' =
			CALCULATE(
			    DISTINCTCOUNT('Portfolio'[Site]),
			    FILTER(
			        'Portfolio',
			        'Portfolio'[Building Utilization Rate] < 0.5 &&
			        NOT(ISBLANK('Portfolio'[Building Utilization Rate]))
			    )
			)
		formatString: #,0
		displayFolder: Portfolio Analysis
		lineageTag: 4177ce20-0369-48ea-84f4-5ca67bab358e

	/// Properties missing rent data or with zero rent
	measure 'Properties with Missing Rent/Acquisition Data' =
			CALCULATE(
			    DISTINCTCOUNT('Portfolio'[Site]),
			    FILTER(
			        ADDCOLUMNS(
			            SUMMARIZE('Portfolio', 'Portfolio'[Site]),
			            "AnnualRent", [Total Annual Rent],
			            "AcquisitionCost", [Total Acquisition Cost]
			        ),
			        (ISBLANK([AnnualRent]) || [AnnualRent] <= 0 ) && (ISBLANK([AcquisitionCost]) || [AcquisitionCost] <= 0 )
			    ), ALL(Portfolio)
			)
		formatString: #,0
		displayFolder: Portfolio Analysis
		lineageTag: 4acba55c-dfa0-4549-91a6-c74d9cc3f3a8

	/// Properties missing area data or with zero area
	measure 'Properties with Missing Area Data' =
			CALCULATE(
			    DISTINCTCOUNT('Portfolio'[Site]),
			    FILTER(
			        'Portfolio',
			        ISBLANK('Portfolio'[Total Building Area (m²)]) ||
			        'Portfolio'[Total Building Area (m²)] <= 0
			    )
			)
		formatString: #,0
		displayFolder: Portfolio Analysis
		lineageTag: 044b4cc7-aa02-488b-be58-fb6671235f0a

	/// Average rent per square meter across property types
	measure 'Average Rent per Sqm by Property Type' =
			AVERAGEX(
			    VALUES('Portfolio'[Property Type (as per Portfolio Lens)]),
			    DIVIDE(
			        CALCULATE([Total Annual Rent with area]),
			        CALCULATE([Total Area (sqm)]),
			        0
			    )
			)
		formatString: #,0.00
		displayFolder: Portfolio Analysis
		lineageTag: df2e967b-7daf-4ede-bcc8-5adf901db5e0

	/// Return on investment for owned properties (Annual Rent / Acquisition Cost)
	measure 'ROI on Owned Properties' =
			DIVIDE(
			    CALCULATE(
			        [Total Annual Rent with area],
			        'Portfolio'[Acquisition Type] = "Owned"
			    ),
			    CALCULATE(
			        SUM('Portfolio'[Acquisition Cost SAR]),
			        'Portfolio'[Acquisition Type] = "Owned"
			    ),
			    0
			)
		formatString: 0.0%
		displayFolder: Portfolio Analysis
		lineageTag: 43cb05e5-f886-41c8-911e-2cb3c5851bec

	/// Count of properties in poor condition requiring attention
	measure 'Properties in Poor Condition' =
			CALCULATE(
			    DISTINCTCOUNT('Portfolio'[Site]),
			    'Portfolio'[Asset Condition] = "Poor"
			)
		formatString: #,0
		displayFolder: Portfolio Analysis
		lineageTag: b86659ef-47c8-46de-a4f7-0a11db91b7ff

	/// Estimated potential rent recovery if underutilized properties reach 50% utilization
	measure 'Potential Rent Recovery (Underutilized)' =
			CALCULATE(
			    SUM('Portfolio'[Annual Rent SAR]) * 0.5,
			    FILTER(
			        'Portfolio',
			        'Portfolio'[Building Utilization Rate] < 0.5 &&
			        NOT(ISBLANK('Portfolio'[Building Utilization Rate])) &&
			        NOT(ISBLANK('Portfolio'[Annual Rent SAR]))
			    )
			)
		formatString: #,0
		displayFolder: Portfolio Analysis
		lineageTag: 6386aed0-08c3-47c5-b091-3e1b7f69b729

	/// Overall portfolio health score (0-100) combining data completeness, utilization, and condition
	measure 'Portfolio Health Score' = ```
			VAR DataCompleteness = 
			    DIVIDE(
			        [Total Sites] - [Properties with Missing Rent/Acquisition Data] - [Properties with Missing Area Data],
			        [Total Sites],
			        0
			    )
			VAR UtilizationScore = 
			    IF([Average Utilization Rate] >= 0.8, 1,
			        IF([Average Utilization Rate] >= 0.5, 0.7, 0.3))
			VAR ConditionScore = 
			    DIVIDE(
			        [Total Sites] - [Properties in Poor Condition],
			        [Total Sites],
			        0
			    )
			RETURN
			    (DataCompleteness * 0.4 + UtilizationScore * 0.4 + ConditionScore * 0.2) * 100
			```
		formatString: 0.0
		displayFolder: Portfolio Analysis
		lineageTag: 8bb6904e-46ed-4672-8147-ca272547e359

	/// Percentage of properties with complete rent and area data
	measure 'Data Completeness %' = ```
			
			 VAR _Missing = COUNTROWS( FILTER(Portfolio, (Portfolio[Rent / Acquisition Cost (SAR)] > 0 && Portfolio[Total Building Area (m²)] > 0)))
			 
			VAR _RESULT =  
			    DIVIDE(
			    _Missing,
			    [Total Sites],
			    0
			) 
			
			
			RETURN _RESULT
			```
		formatString: 0%;-0%;0%
		displayFolder: Portfolio Analysis
		lineageTag: ccecab8d-f947-4e55-b20b-800f04e20e3a

	/// Count of properties by country
	measure 'Properties by Country' =
			CALCULATE(
			    DISTINCTCOUNT('Portfolio'[Site]),
			    ALLSELECTED('Portfolio'[Country])
			)
		formatString: #,0
		displayFolder: Country Analysis
		lineageTag: c98c1ffc-3e37-4d30-a27c-2bcce6df943d

	/// Total area in square meters by country
	measure 'Total Area by Country' =
			CALCULATE(
			    [Total Area (sqm)],
			    ALLSELECTED('Portfolio'[Country])
			)
		formatString: #,0
		displayFolder: Country Analysis
		lineageTag: 3a2c7974-481e-41a4-b2f3-714d7d415b4b

	/// Total annual rent by country
	measure 'Total Annual Rent by Country' =
			CALCULATE(
			    [Total Annual Rent with area],
			    ALLSELECTED('Portfolio'[Country])
			)
		formatString: #,0
		displayFolder: Country Analysis
		lineageTag: 832452e1-97c5-462c-bcf2-b5f174a32dcd

	/// Average rent per square meter by country
	measure 'Avg Rent per Sqm by Country' =
			DIVIDE(
			    [Total Annual Rent by Country],
			    [Total Area by Country],
			    0
			)
		formatString: #,0.00
		displayFolder: Country Analysis
		lineageTag: 92ce29c8-3e83-4474-8567-c328cd583f6c

	/// Average utilization rate by country
	measure 'Avg Utilization by Country' =
			CALCULATE(
			    [Average Utilization Rate],
			    ALLSELECTED('Portfolio'[Country])
			)
		formatString: 0.0%
		displayFolder: Country Analysis
		lineageTag: 66f6695d-62cd-464e-92bb-4d67c780f5a3

	/// Count of leased properties by country
	measure 'Leased Properties by Country' =
			CALCULATE(
			    DISTINCTCOUNT('Portfolio'[Site]),
			    'Portfolio'[Acquisition Type] = "Leased",
			    ALLSELECTED('Portfolio'[Country])
			)
		formatString: #,0
		displayFolder: Country Analysis
		lineageTag: 64742a4c-388e-445b-9df7-d45b32595f75

	/// Count of owned properties by country
	measure 'Owned Properties by Country' =
			CALCULATE(
			    DISTINCTCOUNT('Portfolio'[Site]),
			    'Portfolio'[Acquisition Type] = "Owned",
			    ALLSELECTED('Portfolio'[Country])
			)
		formatString: #,0
		displayFolder: Country Analysis
		lineageTag: 471dd31b-f005-4b9b-a594-6a09b865b57e

	/// Count of allocated properties by country
	measure 'Allocated Properties by Country' =
			CALCULATE(
			    DISTINCTCOUNT('Portfolio'[Site]),
			    'Portfolio'[Acquisition Type] = "Allocated",
			    ALLSELECTED('Portfolio'[Country])
			)
		formatString: #,0
		displayFolder: Country Analysis
		lineageTag: 60cd7d37-bed5-4430-9905-7bab32d13b5d

	/// Count of properties in poor condition by country
	measure 'Poor Condition by Country' =
			CALCULATE(
			    DISTINCTCOUNT('Portfolio'[Site]),
			    'Portfolio'[Asset Condition] = "Poor",
			    ALLSELECTED('Portfolio'[Country])
			)
		formatString: #,0
		displayFolder: Country Analysis
		lineageTag: 67f5327a-52a7-4735-920a-82d14fde9ab5

	/// Count of underutilized properties by country
	measure 'Underutilized by Country' =
			CALCULATE(
			    [Underutilized Properties Count],
			    ALLSELECTED('Portfolio'[Country])
			)
		formatString: #,0
		displayFolder: Country Analysis
		lineageTag: 7eb5df28-eedc-4ecc-ba01-fe26fec695fb

	/// Portfolio health score by country
	measure 'Portfolio Health Score by Country' =
			CALCULATE(
			    [Portfolio Health Score],
			    ALLSELECTED('Portfolio'[Country])
			)
		formatString: 0.0
		displayFolder: Country Analysis
		lineageTag: 5e698dbd-2595-4f40-9d4b-a836006401fc

	/// Properties expiring within 3 years by country
	measure 'Properties Expiring by Country' =
			CALCULATE(
			    [Expiring <=36 Months],
			    ALLSELECTED('Portfolio'[Country])
			)
		formatString: #,0
		displayFolder: Country Analysis
		lineageTag: e41da63f-6ccf-4fbf-84b0-ff05d94383a2

	measure 'Properties with Area and Cost Data' = COUNTROWS( FILTER(Portfolio, (Portfolio[Rent / Acquisition Cost (SAR)] > 0 && Portfolio[Total Building Area (m²)] > 0)))
		formatString: 0
		lineageTag: 0c4fbc7d-4e1f-4a93-89dd-ef810f06301f

	measure 'Total Cost' =
			SWITCH(
			                    SELECTEDVALUE(Portfolio[Acquisition Type]),
			                    "Owned", [Total Acquisition Cost], [Total Annual Rent]
			
			)
		lineageTag: eddc6b83-0e3a-44bb-9686-70102b08a33a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Properties with Missing Area and Cost' = COUNTROWS( FILTER(Portfolio, (Portfolio[Rent / Acquisition Cost (SAR)] <= 0 && Portfolio[Total Building Area (m²)] <= 0)))
		formatString: 0
		lineageTag: 71d6515f-1701-445a-9bf8-85043817a40d

	measure 'Upcoming Renewal Sites' = ```
			
			       VAR _renewal =  CALCULATE(
			            COUNTROWS(Portfolio),
			            DATEDIFF(TODAY(), 'Portfolio'[Lease End Date ], MONTH) <= 36 &&
			            DATEDIFF(TODAY(), 'Portfolio'[Lease End Date ], MONTH) > 0
			        )
			        RETURN _renewal
			```
		formatString: 0
		lineageTag: 9128ef1b-43a7-495b-b592-cc25244f34b9

