	measure 'Total Annual Rent (SAR)' = ```
			
			        SUMX(
			            'Portfolio',
			            VAR AnnualMultiplier = 
			                SWITCH(
			                    'Portfolio'[Lease Payment Frequency],
			                    "Semi-Annual ", 2,
			                    "Quarterly", 4,
			                    "Annual", 1,
			                    1  // Default to annual if not specified
			                )
			            RETURN
			               // 'Portfolio'[ Lease Cost  ] * AnnualMultiplier * 
			               'Portfolio'[Lease Cost  ] * AnnualMultiplier * 
			                'Portfolio'[Exchange Rate vs. SAR (per XE.com)]
			        )
			```
		lineageTag: 59bb7f05-3a1f-48bc-a9e1-5a655241eac4

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Annual Rent (USD)' = ```
			
			        // Note: Uses USD/SAR exchange rate from parameter table
			        VAR USDToSARRate = COALESCE(SELECTEDVALUE('USD to AR ExRate'[USD to AR ExRate]), 3.75)
			        RETURN
			            DIVIDE([Total Annual Rent (SAR)], USDToSARRate, 0)
			```
		lineageTag: b8f5c59d-f997-4eb1-97c9-c4cda8dfc589

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Area (sqm)' = ```
			
