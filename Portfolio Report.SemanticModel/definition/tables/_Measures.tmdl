	measure 'Median Rent to Area Ratio' = ```
			
			        MEDIANX(
			            FILTER(
			                ADDCOLUMNS(
			                    SUMMARIZE('Portfolio', 'Portfolio'[Site]),
			                    "Ratio", [Net Rent to Area Ratio ($/sqm)]
			                ),
			                [Ratio] > 0
			            ),
			            [Ratio]
			        )
			```
		displayFolder: Distribution
		lineageTag: 9db8f053-210e-4cb0-a7ea-29e5b4d36f48

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Rent to Area Ratio Std Dev' = ```
			
			        STDEVX.P(
			            'Portfolio',
			            CALCULATE([Net Rent to Area Ratio ($/sqm)])
			        )
			```
		lineageTag: 31c38273-a875-4d6c-ace3-62bcecc4fe66

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Outlier Threshold High' = ```
			
			        [Average Rent to Area Ratio] + (2 * [Rent to Area Ratio Std Dev])
			```
		lineageTag: 85478c57-72fa-4147-a305-10c7bce7c703

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Outlier Threshold Low' = ```
			
			        [Average Rent to Area Ratio] - (2 * [Rent to Area Ratio Std Dev])
			```
		lineageTag: 0e84c3b0-db87-4513-b9b4-7e7e2466feb1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Properties Above 20% Variance' = ```
			
			        CALCULATE(
			            DISTINCTCOUNT('Portfolio'[Site]),
			            FILTER(
			                'Portfolio',
			                VAR AvgRatio = [Average Rent to Area Ratio]
			                VAR PropertyRatio = CALCULATE([Net Rent to Area Ratio ($/sqm)])
			                RETURN
			                    PropertyRatio > (AvgRatio * 1.20) || PropertyRatio < (AvgRatio * 0.80)
			            )
			        )
			```
		formatString: 0
		lineageTag: 3eae815e-820f-49e7-8ece-0a8e39b0ab89

	measure 'Outlier Properties Count' = ```
			
			        CALCULATE(
			            DISTINCTCOUNT('Portfolio'[Site]),
			            FILTER(
			                'Portfolio',
			                VAR PropertyRatio = CALCULATE([Net Rent to Area Ratio ($/sqm)])
			                RETURN
			                    PropertyRatio > [Outlier Threshold High] || 
			                    PropertyRatio < [Outlier Threshold Low]
			            )
			        )
			```
		formatString: 0
		lineageTag: b1612b6b-1d1d-40c5-b4b3-61131c7cc04a

