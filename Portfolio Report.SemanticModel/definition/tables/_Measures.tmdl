	measure 'Total Annual Rent with area' = ```
			
			        // Currency selection measure for sites with area data
			        VAR _selectedCurr = SELECTEDVALUE('Currency Selection'[CurrencyOrder], 1)
			        RETURN 
			            SWITCH(
			                _selectedCurr, 
			                1, [Total Annual Rent with Area(USD)], 
			                2, [Total Annual Rent with Area (SAR)]
			            )
			```
		formatString: #,0.00
		lineageTag: 99303dc4-9822-43b0-86ba-c37ceeaeda7d

	measure 'Button - Info' = ```
			
			    // VAR Lang = [Selected Language]
			    // RETURN
			    //     IF(Lang = "AR", "معلومات", "Info")
			
			VAR lang = '_Measures'[Selected Language]
			RETURN IF(
			    lang = "AR",
			    LOOKUPVALUE('Translations'[AR], 'Translations'[Key], "BUTTON_INFORMATION"),
			    LOOKUPVALUE('Translations'[EN], 'Translations'[Key], "BUTTON_INFORMATION")
			)
			```
		lineageTag: 1194aa0c-5f8e-4f14-9199-0a2b01d6e61a

	measure 'Selected Language' =
			
			VAR Lang = SELECTEDVALUE('Language'[Code], "EN")
			RETURN Lang
		lineageTag: ea4fd230-82d5-44e1-92e7-392566d9ac33

