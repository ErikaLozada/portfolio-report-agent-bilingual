	measure 'Expiring <=36 Months' = ```
			
			
			VAR _count = 
			        CALCULATE(
			            DISTINCTCOUNT('Portfolio'[Site]),
			            DATEDIFF(TODAY(), 'Portfolio'[Lease End Date ], MONTH) <= 36 &&
			            DATEDIFF(TODAY(), 'Portfolio'[Lease End Date ], MONTH) > 0
			        )
			
			RETURN
			_count
			```
		lineageTag: 30634234-4bb9-4c07-9e82-7cc0c5347cfa

		formatStringDefinition = "#"

	measure 'Upcoming Total Rent Lease Ending < 3 yrs' = ```
			
			        CALCULATE(
			            [Total Annual Rent],
			            DATEDIFF(TODAY(), 'Portfolio'[Lease End Date ], MONTH) <= 36 &&
			            DATEDIFF(TODAY(), 'Portfolio'[Lease End Date ], MONTH) > 0
			        )
			```
		formatString: #,0
		lineageTag: 523cec8a-58cc-47ba-be6b-95b9e04b5979

		annotation PBI_FormatHint = {"isDecimal":true}

