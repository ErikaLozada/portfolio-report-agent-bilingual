{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.4.0/schema.json",
  "name": "{{visual_id}}",
  "position": {
    "x": "{{position.x}}",
    "y": "{{position.y}}",
    "z": "{{position.z}}",
    "height": "{{position.height}}",
    "width": "{{position.width}}",
    "tabOrder": "{{position.tabOrder}}"
  },
  "visual": {
    "visualType": "tableEx",
    "query": {
      "queryState": {
        "Values": {
          "projections": []
        }
      }
    },
    "objects": {
      "grid": [
        {
          "properties": {
            "rowPadding": {
              "expr": {
                "Literal": {
                  "Value": "2D"
                }
              }
            }
          }
        }
      ],
      "columnHeaders": [
        {
          "properties": {
            "outlineStyle": {
              "expr": {
                "Literal": {
                  "Value": "4D"
                }
              }
            },
            "outlineColor": {
              "solid": {
                "color": {
                  "expr": {
                    "ThemeDataColor": {
                      "ColorId": 1,
                      "Percent": 0.6
                    }
                  }
                }
              }
            },
            "fontFamily": {
              "expr": {
                "Literal": {
                  "Value": "'''Segoe UI Light'', wf_segoe-ui_light, helvetica, arial, sans-serif'"
                }
              }
            },
            "wordWrap": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            },
            "autoSizeColumnWidth": {
              "expr": {
                "Literal": {
                  "Value": "false"
                }
              }
            },
            "alignment": {
              "expr": {
                "Literal": {
                  "Value": "'right'"
                }
              }
            }
          }
        }
      ],
      "total": [
        {
          "properties": {
            "outlineStyle": {
              "expr": {
                "Literal": {
                  "Value": "0D"
                }
              }
            }
          }
        }
      ],
      "values": [
        {
          "properties": {
            "fontFamily": {
              "expr": {
                "Literal": {
                  "Value": "'''Segoe UI Light'', wf_segoe-ui_light, helvetica, arial, sans-serif'"
                }
              }
            }
          }
        }
      ]
    },
    "visualContainerObjects": {
      "stylePreset": [
        {
          "properties": {
            "name": {
              "expr": {
                "Literal": {
                  "Value": "'Minimal'"
                }
              }
            }
          }
        }
      ],
      "title": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            },
            "fontFamily": {
              "expr": {
                "Literal": {
                  "Value": "'''Segoe UI Light'', wf_segoe-ui_light, helvetica, arial, sans-serif'"
                }
              }
            },
            "alignment": {
              "expr": {
                "Literal": {
                  "Value": "'right'"
                }
              }
            }
          }
        }
      ],
      "subTitle": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "false"
                }
              }
            },
            "alignment": {
              "expr": {
                "Literal": {
                  "Value": "'right'"
                }
              }
            }
          }
        }
      ],
      "spacing": [
        {
          "properties": {
            "verticalSpacing": {
              "expr": {
                "Literal": {
                  "Value": "2D"
                }
              }
            }
          }
        }
      ],
      "padding": [
        {
          "properties": {
            "left": {
              "expr": {
                "Literal": {
                  "Value": "20D"
                }
              }
            },
            "top": {
              "expr": {
                "Literal": {
                  "Value": "10D"
                }
              }
            },
            "bottom": {
              "expr": {
                "Literal": {
                  "Value": "20D"
                }
              }
            },
            "right": {
              "expr": {
                "Literal": {
                  "Value": "20D"
                }
              }
            }
          }
        }
      ]
    },
    "drillFilterOtherVisuals": true
  }
}
