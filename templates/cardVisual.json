{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.4.0/schema.json",
  "name": "{{visual_id}}",
  "position": {
    "x": "{{position.x}}",
    "y": "{{position.y}}",
    "z": "{{position.z}}",
    "height": "{{position.height}}",
    "width": "{{position.width}}",
    "tabOrder": "{{position.tabOrder}}"
  },
  "visual": {
    "visualType": "cardVisual",
    "query": {
      "queryState": {
        "Data": {
          "projections": []
        }
      }
    },
    "objects": {
      "layout": [
        {
          "properties": {
            "maxTiles": {
              "expr": {
                "Literal": {
                  "Value": "6L"
                }
              }
            },
            "alignment": {
              "expr": {
                "Literal": {
                  "Value": "'top'"
                }
              }
            },
            "style": {
              "expr": {
                "Literal": {
                  "Value": "'Cards'"
                }
              }
            }
          }
        }
      ],
      "outline": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "false"
                }
              }
            }
          },
          "selector": {
            "id": "default"
          }
        }
      ],
      "fillCustom": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "false"
                }
              }
            }
          }
        }
      ],
      "accentBar": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            },
            "width": {
              "expr": {
                "Literal": {
                  "Value": "1D"
                }
              }
            },
            "color": {
              "solid": {
                "color": {
                  "expr": {
                    "ThemeDataColor": {
                      "ColorId": 0,
                      "Percent": -0.1
                    }
                  }
                }
              }
            }
          },
          "selector": {
            "id": "default"
          }
        }
      ],
      "value": [
        {
          "properties": {
            "fontSize": {
              "expr": {
                "Literal": {
                  "Value": "26D"
                }
              }
            }
          },
          "selector": {
            "id": "default"
          }
        }
      ],
      "label": [
        {
          "properties": {
            "fontColor": {
              "solid": {
                "color": {
                  "expr": {
                    "ThemeDataColor": {
                      "ColorId": 1,
                      "Percent": 0
                    }
                  }
                }
              }
            },
            "fontFamily": {
              "expr": {
                "Literal": {
                  "Value": "'''Segoe UI Light'', wf_segoe-ui_light, helvetica, arial, sans-serif'"
                }
              }
            },
            "fontSize": {
              "expr": {
                "Literal": {
                  "Value": "10D"
                }
              }
            },
            "matchValueAlignment": {
              "expr": {
                "Literal": {
                  "Value": "false"
                }
              }
            },
            "alignBaselines": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            },
            "horizontalAlignment": {
              "expr": {
                "Literal": {
                  "Value": "'left'"
                }
              }
            }
          },
          "selector": {
            "id": "default"
          }
        }
      ],
      "padding": [
        {
          "properties": {
            "paddingSelection": {
              "expr": {
                "Literal": {
                  "Value": "'Normal'"
                }
              }
            }
          },
          "selector": {
            "id": "default"
          }
        }
      ],
      "divider": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "false"
                }
              }
            },
            "dividerIgnorePadding": {
              "expr": {
                "Literal": {
                  "Value": "false"
                }
              }
            }
          },
          "selector": {
            "id": "default"
          }
        }
      ],
      "referenceLabelValue": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "false"
                }
              }
            }
          },
          "selector": {
            "id": "default"
          }
        }
      ],
      "referenceLabelTitle": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "false"
                }
              }
            }
          },
          "selector": {
            "id": "default"
          }
        }
      ],
      "referenceLabelDetail": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "false"
                }
              }
            }
          },
          "selector": {
            "id": "default"
          }
        }
      ],
      "border": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "false"
                }
              }
            }
          },
          "selector": {
            "id": "default"
          }
        }
      ]
    },
    "visualContainerObjects": {
      "padding": [
        {
          "properties": {
            "top": {
              "expr": {
                "Literal": {
                  "Value": "10D"
                }
              }
            },
            "bottom": {
              "expr": {
                "Literal": {
                  "Value": "10D"
                }
              }
            },
            "right": {
              "expr": {
                "Literal": {
                  "Value": "20D"
                }
              }
            },
            "left": {
              "expr": {
                "Literal": {
                  "Value": "20D"
                }
              }
            }
          }
        }
      ],
      "title": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "false"
                }
              }
            },
            "fontFamily": {
              "expr": {
                "Literal": {
                  "Value": "'''Segoe UI Light'', wf_segoe-ui_light, helvetica, arial, sans-serif'"
                }
              }
            }
          }
        }
      ]
    },
    "drillFilterOtherVisuals": true
  }
}
